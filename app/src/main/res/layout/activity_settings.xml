<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ece2d0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#6d2e46"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OpenRouter API key"
            android:textColor="#a26769"
            android:textSize="13sp"
            android:paddingBottom="4dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <EditText
                android:id="@+id/field_api_key"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="textPassword"
                android:textColor="#6d2e46"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:hint="sk-or-..."
                android:textColorHint="#a26769" />
            <Button
                android:id="@+id/toggle_key_visibility"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="&#128065;"
                android:textSize="18sp"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:minWidth="0dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Model"
            android:textColor="#a26769"
            android:textSize="13sp"
            android:paddingBottom="4dp" />
        <EditText
            android:id="@+id/field_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="#6d2e46"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Timezone"
            android:textColor="#a26769"
            android:textSize="13sp"
            android:paddingBottom="4dp" />
        <EditText
            android:id="@+id/field_timezone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="#6d2e46"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:hint="e.g. Europe/Rome"
            android:textColorHint="#a26769" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Language"
            android:textColor="#a26769"
            android:textSize="13sp"
            android:paddingBottom="4dp" />
        <Spinner
            android:id="@+id/spinner_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/input_bg"
            android:popupBackground="#2A2A2A" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Schedule (freeform)"
            android:textColor="#a26769"
            android:textSize="13sp"
            android:paddingBottom="4dp" />
        <EditText
            android:id="@+id/field_schedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2"
            android:textColor="#6d2e46"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:layout_marginBottom="24dp"
            android:hint="e.g. weekdays 9-13 and 15-19"
            android:textColorHint="#a26769" />

        <Button
            android:id="@+id/save_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="#ece2d0"
            android:background="@drawable/btn_send_bg"
            android:padding="14dp"
            android:layout_marginBottom="32dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#d5b9b2"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/clear_history_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear conversation history"
            android:textColor="#a26769"
            android:background="@drawable/btn_secondary_bg"
            android:padding="14dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/clear_tasks_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear all tasks"
            android:textColor="#a26769"
            android:background="@drawable/btn_secondary_bg"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
